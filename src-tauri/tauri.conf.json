{
  "productName": "copyspeak",
  "version": "0.1.9",
  "identifier": "com.copyspeak.tts",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "CopySpeak",
    "shortDescription": "Clipboard text-to-speech tool",
    "longDescription": "A lightweight tool for quick AI text-to-speech generation.",
    "category": "Productivity",
    "resources": {
      "../scripts/install-*.ps1": "scripts/",
      "../scripts/lib/*.ps1": "scripts/lib/"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "devCsp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "CopySpeak",
        "width": 775,
        "height": 580,
        "resizable": false,
        "center": true,
        "visible": true,
        "devtools": true
      },
      {
        "label": "hud",
        "title": "",
        "url": "/hud",
        "width": 300,
        "height": 140,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "backgroundColor": [0, 0, 0, 0],
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/ilyaizen/CopySpeak/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5NEU5MjFEMEZBOUQ5MApSV1NRbmZyUUllbVVEbkwrajB5ZjNXbml2U2tuTTZXVmhhektTS2RxM1dYaks5TC9SY0I2alVwRQo=",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
