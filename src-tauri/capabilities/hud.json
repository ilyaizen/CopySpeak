{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "hud",
  "description": "Capabilities for the HUD overlay window",
  "windows": ["hud"],
  "permissions": [
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-outer-position"
  ]
}
