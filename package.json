{
  "name": "copyspeak-tts",
  "version": "0.1.5",
  "description": "A simple and configurable AI-generated Text-to-Speech (TTS) orchestrator for Windows",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "tauri": "tauri",
    "bump": "node ./scripts/version-bumper.mjs patch",
    "bump:minor": "node ./scripts/version-bumper.mjs minor",
    "bump:major": "node ./scripts/version-bumper.mjs major",
    "fix": "powershell -ExecutionPolicy Bypass -File ./scripts/fix-ports.ps1",
    "tree": "wsl bash -c \"tree -a -I 'node_modules|.next|src-tauri/target|.git|prompts|skills|.vercel|dist|out|gen|target|.svelte-kit|.obsidian|ui|build|icons|.agent|.agents|.claude|.tauri|.ruff_cache|__pycache__|.gemini|.opencode|.kilocode|archive|backups|bun.lock|openspec|.planning' --noreport --dirsfirst > file-structure.txt\""
  },
  "license": "MIT",
  "dependencies": {
    "@fontsource/lato": "^5.2.7",
    "@lucide/svelte": "^1.17.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "clsx": "^2.1.1",
    "mode-watcher": "^1.1.0",
    "svelte-i18n": "^4.0.1",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.2",
    "@playwright/test": "^1.60.0",
    "@rollup/rollup-linux-x64-gnu": "^4.61.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.64.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.9.2",
    "@vitest/ui": "^4.1.8",
    "bits-ui": "^2.18.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
