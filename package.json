{
  "name": "copyspeak",
  "version": "0.0.5",
  "description": "A simple and configurable AI-generated Text-to-Speech (TTS) orchestrator for Windows",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "tauri": "tauri",
    "bump": "node ./scripts/version-bumper.mjs patch",
    "bump:minor": "node ./scripts/version-bumper.mjs minor",
    "bump:major": "node ./scripts/version-bumper.mjs major",
    "fix": "powershell -ExecutionPolicy Bypass -File ./scripts/fix-ports.ps1",
    "tree": "wsl bash -c \"tree -a -I 'node_modules|.next|src-tauri/target|.git|prompts|skills|.vercel|dist|out|gen|target|.svelte-kit|.obsidian|ui|build|icons|.agent|.agents|.claude|.tauri|.ruff_cache|__pycache__|.gemini|.opencode|.kilocode|archive|backups|bun.lock|openspec' --noreport --dirsfirst > file-structure.txt\""
  },
  "license": "MIT",
  "dependencies": {
    "@fontsource/lato": "^5.2.7",
    "@lucide/svelte": "^1.0.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "clsx": "^2.1.1",
    "mode-watcher": "^1.1.0",
    "svelte-i18n": "^4.0.1",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.0",
    "@playwright/test": "^1.58.2",
    "@rollup/rollup-linux-x64-gnu": "^4.59.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/ui": "^4.1.0",
    "bits-ui": "^2.16.3",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
